rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function chatPath(chatId) {
      return /databases/$(database)/documents/chats/$(chatId);
    }

    function isParticipant(chatId) {
      return isSignedIn()
        && exists(chatPath(chatId))
        && request.auth.uid in get(chatPath(chatId)).data.participants;
    }

    match /chats/{chatId} {
      allow read: if isParticipant(chatId);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'participants',
          'createdAt',
          'updatedAt',
          'lastMessageText',
          'lastMessageSenderId',
          'lastMessageCreatedAt'
        ])
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;

      allow update: if isParticipant(chatId)
        && request.resource.data.participants == resource.data.participants;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant(chatId);

        allow create: if isParticipant(chatId)
          && request.resource.data.keys().hasOnly([
            'text',
            'senderId',
            'createdAt',
            'deliveredTo',
            'seenBy'
          ])
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.deliveredTo == [request.auth.uid]
          && request.resource.data.seenBy == [request.auth.uid];

        allow update: if isParticipant(chatId)
          && resource.data.senderId != request.auth.uid
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.text == resource.data.text
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.deliveredTo.hasAll(resource.data.deliveredTo)
          && request.resource.data.seenBy.hasAll(resource.data.seenBy)
          && request.auth.uid in request.resource.data.deliveredTo
          && (
            request.resource.data.seenBy == resource.data.seenBy
            || request.auth.uid in request.resource.data.seenBy
          );

        allow delete: if false;
      }

      match /typing/{userId} {
        allow read: if isParticipant(chatId);

        allow create, update: if isParticipant(chatId)
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['isTyping', 'updatedAt'])
          && request.resource.data.isTyping is bool;

        allow delete: if isParticipant(chatId) && request.auth.uid == userId;
      }
    }

    match /presence/{userId} {
      allow read: if isSignedIn();

      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['state', 'lastActive', 'lastChanged'])
        && request.resource.data.state in ['online', 'offline'];

      allow delete: if false;
    }
  }
}
